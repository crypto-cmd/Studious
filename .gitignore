# ---------------------------
# Global OS / editor artifacts
# ---------------------------
.DS_Store
Thumbs.db

.idea/
.vscode/

# ---------------------------
# Python (backend)
# ---------------------------
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd

**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.hypothesis/
**/.coverage
**/.coverage.*
**/htmlcov/

# Virtual environments
**/.venv/
**/venv/

# Packaging / build outputs
**/build/
**/dist/
**/*.egg-info/

# ---------------------------
# JavaScript / TypeScript (frontend, marketing)
# ---------------------------
**/node_modules/
**/.next/
**/.nuxt/
**/.svelte-kit/
**/out/
**/coverage/
**/*.tsbuildinfo
**/.eslintcache
**/.cache/

# Build artifacts
**/dist/
**/*.tgz

# ---------------------------
# Environment & local secrets
# ---------------------------
**/.env
**/.env.local
**/.env.*.local

# Keep checked-in examples if present
!**/.env.example
!**/.env.*.example

# ---------------------------
# Logs & runtime temp
# ---------------------------
**/logs/
**/*.log
**/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
*.pid
*.seed
*.stackdump

# ──────────────────────────────────────────────
# Studious — Docker Compose Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# ─── Backend (Flask API) ────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
GROQ_API_KEY=gsk_your_groq_api_key
PINECONE_API_KEY=pcsk_your_pinecone_api_key
PINECONE_INDEX_NAME=course-materials
HF_TOKEN=hf_your_huggingface_token

# ─── Frontend (Next.js App) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_BACKEND_URL=http://backend:7860
NEXT_PUBLIC_SITE_URL=http://app.studious.local

# ─── Domain Configuration ───────────────────
# For local dev, add to /etc/hosts:
#   127.0.0.1 studious.local app.studious.local
DOMAIN=studious.local
APP_DOMAIN=app.studious.local
